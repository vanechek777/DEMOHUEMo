<Window x:Class="ShoesStore.Catalog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShoesStore"
        mc:Ignorable="d"
        Title="Каталог" Height="450" Width="800">
    <DockPanel Margin="10 0">
        <DockPanel DockPanel.Dock="Top">
            <TextBlock Text="Каталог товаров" Margin="0 10" FontSize="20" FontFamily="Times New Roman" FontWeight="Bold"></TextBlock>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                <TextBlock x:Name="userFullName" Text="Иванов Иван Иванович" Margin="10 10 0 10" FontSize="15" FontFamily="Times New Roman" VerticalAlignment="Center"></TextBlock>
                <Button Margin="10 0 0 0" x:Name="leave" Content="Выйти" VerticalAlignment="Center" Click="leave_Click"></Button>
            </StackPanel>
        </DockPanel>
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0 0 0 10" x:Name="Filter">
            <StackPanel Margin="0 0 10 0">
                <TextBlock Text="Сортировать по:"></TextBlock>
                <ComboBox x:Name="sortSupply" Width="120"></ComboBox>
            </StackPanel>
            <StackPanel Margin="0 0 10 0">
                <TextBlock Text="Поставщик:"></TextBlock>
                <ComboBox x:Name="filterManufacturer" Width="120"></ComboBox>
            </StackPanel>
            <StackPanel Margin="0 0 10 0">
                <TextBlock Text="Поиск:"></TextBlock>
                <TextBox x:Name="searchTb" Width="130" Height="22"></TextBox>
            </StackPanel>
            <Button x:Name="clearBtn" Content="Очистить" VerticalAlignment="Bottom" HorizontalAlignment="Right" Height="22" Click="clearBtn_Click"></Button>
        </StackPanel>
        <StackPanel DockPanel.Dock="Top" Margin="0 0 0 10" Orientation="Horizontal" x:Name="adminAct">
            <Button x:Name="orderBtn" HorizontalAlignment="Left" Content="Заказы" Background="#00FA9A" Margin="0 0 10 0" Click="orderBtn_Click"></Button>
            <Button x:Name="newProdBtn" HorizontalAlignment="Left" Content="Добавить товар" Background="#00FA9A" Click="newProdBtn_Click"></Button>
        </StackPanel>
        <ScrollViewer x:Name="prod" Visibility="Visible">
            <StackPanel Orientation="Vertical" x:Name="productCards">
                <Border BorderBrush="Black" BorderThickness="1" Margin="0 0 0 10" Background="#7FFF00" x:Name="prodCard" DataContext="null" MouseLeftButtonDown="prodCard_MouseLeftButtonDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="112px"></ColumnDefinition>
                            <ColumnDefinition Width="*"></ColumnDefinition>
                            <ColumnDefinition Width="200px"></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <Border BorderBrush="Black" BorderThickness="1" VerticalAlignment="Stretch" Grid.Column="0">
                            <StackPanel VerticalAlignment="Stretch">
                                <Image Source="/Resources/1.jpg" Width="112" x:Name="prodImage"></Image>
                            </StackPanel>
                        </Border>
                        <Border BorderBrush="Black" BorderThickness="1" VerticalAlignment="Stretch" Grid.Column="1">
                            <StackPanel Orientation="Vertical" Margin="10 0" VerticalAlignment="Stretch">
                                <TextBlock x:Name="prodCatName" Text="Категория товара | Наименование товара" FontWeight="Bold" ></TextBlock>
                                <TextBlock x:Name="prodDesc" Text="Описание товара:"></TextBlock>
                                <TextBlock x:Name="prodManuf" Text="Производитель: "></TextBlock>
                                <TextBlock x:Name="prodSupp" Text="Поставщик: "></TextBlock>
                                <TextBlock x:Name="prodPrice" Text="Цена: "></TextBlock>
                                <TextBlock x:Name="prodUnit" Text="Ед. измерения: "></TextBlock>
                                <TextBlock x:Name="prodCount" Text="Количество на складе: "></TextBlock>
                            </StackPanel>
                        </Border>
                        <Grid Grid.Column="2">
                            <WrapPanel Orientation="Vertical" Margin="0 0 0 0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="Действующая скидка" HorizontalAlignment="Center"></TextBlock>
                                <TextBlock x:Name="prodDiscount" Text="15%" HorizontalAlignment="Center"></TextBlock>
                            </WrapPanel>
                        </Grid>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
