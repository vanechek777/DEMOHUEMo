<Window x:Class="ShoesStore.Order"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShoesStore"
        mc:Ignorable="d"
        Title="Order" Height="450" Width="800">
    <DockPanel Margin="10 10">
        <Button Content="Добавить заказ" Margin="0 0 0 10" x:Name="addOrderBtn" DockPanel.Dock="Top"></Button>
        <ScrollViewer Visibility="Visible" DockPanel.Dock="Top" MinHeight="350">
            <StackPanel Orientation="Vertical" x:Name="orderScroll">

            </StackPanel>
        </ScrollViewer>
        <Button x:Name="backBtn" DockPanel.Dock="Top" Content="Назад" Height="20" HorizontalAlignment="Left" Width="100"></Button>
    </DockPanel>
</Window>
