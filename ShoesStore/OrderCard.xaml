<UserControl x:Class="ShoesStore.OrderCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ShoesStore"
             mc:Ignorable="d">
    <Border BorderBrush="Black" BorderThickness="1" Margin="0 0 0 10" Background="#7FFF00">
        <Grid Margin="10 10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="200px"></ColumnDefinition>
            </Grid.ColumnDefinitions>
            <Border BorderBrush="Black" BorderThickness="1" VerticalAlignment="Stretch" Grid.Column="0">
                <StackPanel Orientation="Vertical" Margin="10 5" VerticalAlignment="Stretch">
                    <TextBlock x:Name="orderId" Text="Артикул заказа: " FontWeight="Bold" ></TextBlock>
                    <TextBlock x:Name="orderStatus" Text="Статус заказа:"></TextBlock>
                    <TextBlock x:Name="pupAdress" Text="Адрес пункта выдачи: "></TextBlock>
                    <TextBlock x:Name="createdAt" Text="Дата заказа: "></TextBlock>
                </StackPanel>
            </Border>
            <Grid Grid.Column="2">
                <Border BorderThickness="1" BorderBrush="Black">
                    <WrapPanel Orientation="Vertical" Margin="0 0 0 0" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="Дата доставки:" HorizontalAlignment="Center"></TextBlock>
                        <TextBlock x:Name="arriveDate" Text="21.04.2006" HorizontalAlignment="Center"></TextBlock>
                    </WrapPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
