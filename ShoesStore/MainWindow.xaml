<Window x:Class="ShoesStore.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShoesStore"
        mc:Ignorable="d"
        Title="Авторизация" Height="450" Width="300" Icon="/Resources/Icon.ico">
    <Grid>
        <StackPanel Orientation="Vertical">
            <Image Source="/Resources/Icon.png" Width="100" Margin="0 10 0 0"></Image>
            <TextBlock Text="ООО Обувь" TextAlignment="Center" Margin="0 0" FontSize="20" FontFamily="Times New Roman"/>
            <TextBlock Text="Авторизация" TextAlignment="Center" Margin="0 20" FontSize="20" FontFamily="Times New Roman"/>
            <StackPanel>
                <TextBlock Text="Логин" Margin="20 20 20 0"></TextBlock>
                <TextBox Margin="20 0" x:Name="login"></TextBox>
                <TextBlock Text="Пароль" Margin="20 10 20 0"></TextBlock>
                <PasswordBox Margin="20 0" x:Name="password"></PasswordBox>
                <StackPanel Margin="0 15 0 0" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Войти как гость" Margin="0 0 10 0" Width="100" x:Name="EnterAsGuest" Click="EnterAsGuest_Click"></Button>
                    <Button Content="Войти" Margin="10 0 0 0" Width="100" Background="#00FA9A" x:Name="Enter" Click="Enter_Click"></Button>
                </StackPanel>
                
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
